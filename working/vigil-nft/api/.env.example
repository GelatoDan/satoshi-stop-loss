# =============================================
# The Vigil — Metadata API Environment Variables
# Copy to .env and fill in values before running
# =============================================

# Server
PORT=3001
NODE_ENV=production

# Contract (fill in after deployment)
VIGIL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Base RPC
# Free: https://mainnet.base.org
# Better: get a key from Alchemy or QuickNode for production
BASE_RPC_URL=https://mainnet.base.org

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://thevigilnft.xyz,https://mint.thevigilnft.xyz

# Royalty recipient for /collection endpoint
ROYALTY_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# Admin API key — used to clear metadata caches (generate a random string)
ADMIN_API_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
