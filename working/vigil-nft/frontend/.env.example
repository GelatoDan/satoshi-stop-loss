# =============================================
# The Vigil — Frontend Environment Variables
# Copy to .env.local and fill in before running
# =============================================

# Contract address (fill in after deployment)
NEXT_PUBLIC_VIGIL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# API URL
NEXT_PUBLIC_API_URL=https://api.thevigilnft.xyz

# WalletConnect project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Set to "true" to use Base Sepolia testnet instead of mainnet
NEXT_PUBLIC_USE_TESTNET=false
